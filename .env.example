# Copy to .env and fill in values
# Polymarket — no auth required for public market data
# POLYMARKET_API_KEY=  # only needed for trading

# Kalshi — no auth required for public read-only REST API
# KALSHI_API_KEY_ID=   # only needed for trading
# KALSHI_PRIVATE_KEY=  # only needed for trading

# Logging
LOG_LEVEL=INFO
